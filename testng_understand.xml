<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">


<!--
exectn order at suite level::
1. @BeforeSuite
2. <test> #1  zmoke
3. <test> #2  regre
4. <test> #3 negeative
5. @AfterSuite

-->

<suite name="Enterprise BankAccount Suite"
       parallel="methods"
       thread-count="4">

    <listeners>
        <listener class-name="com.epam.campus.listeners.BankAccountTestListener"/>
        <listener class-name="com.epam.campus.listeners.RetryTransformer"/>
    </listeners>

    <parameter name="initialAmount" value="1000"/>
    <parameter name="withdrawAmount" value="200" />
    <parameter name="expectedBalance" value="800" />

    <test name="Smoke Tests">
        <!-- say we have 2 test class
        @BeforeTest

        Class1:
            @BeforeClass
                @BeforeMethod
                @Test (method1)
                @AfterMethod

                @BeforeMethod
                @Test (method2)
                @AfterMethod
            @AfterClass

        Class2:
            @BeforeClass
                @BeforeMethod
                @Test (method1)
                @AfterMethod

                @BeforeMethod
                @Test (method2)
                @AfterMethod
            @AfterClass

        @AfterTest


        Notes:
        @BeforeTest runs once per <test> tag in testng.xml (NOT per class).
        @BeforeClass runs once per class. ( If you want something to run before each class → use @BeforeClass. )
        @BeforeMethod runs before each @Test method.

        -->



        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.epam.campus.tests"/>
        </packages>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.epam.campus.tests"/>
        </packages>
    </test>

    <test name="Negative Tests">
        <groups>
            <run>
                <include name="negative"/>
            </run>
        </groups>
        <packages>
            <package name="com.epam.campus.tests"/>
        </packages>
    </test>

</suite>
